{
  "expo": {
    "name": "ElasticClaw",
    "slug": "elasticclaw",
    "version": "1.0.0",
    "scheme": "elasticclaw",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.elasticclaw.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.elasticclaw.mobile"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c83311c8-b71c-435a-a1af-13cfcc39c24d"
      }
    }
  }
}
